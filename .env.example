# 이 파일을 복사해서 `.env` 로 만들고 실제 키를 채우세요. (.env 는 절대 커밋 금지)
# cp .env.example .env

# --- 한국관광공사 / 공공데이터포털 (필수) ---
# 발급: https://data.go.kr  →  "한국관광공사 국문 관광정보 서비스" 활용신청
TOURAPI_SERVICE_KEY=

# 발급: https://data.go.kr  →  "한국관광공사 지역별 방문자수" 활용신청 (예측 라벨용)
VISITOR_API_SERVICE_KEY=

# --- 지도 (Tier 0~, 주차/숙소/위치 표시용) ---
# 발급: https://developers.kakao.com
KAKAO_MAP_API_KEY=

# --- 날씨 (feature, 선택) ---
# 발급: https://data.go.kr  →  기상청 단기예보/과거관측
WEATHER_API_SERVICE_KEY=

# --- LLM (Tier 2 보완 리포트 생성) ---
# 발급: https://console.anthropic.com
ANTHROPIC_API_KEY=
